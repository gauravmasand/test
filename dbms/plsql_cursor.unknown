create table O_Roll_Call(rollno int primary key,name varchar(50));

create table N_Roll_Call(rollno int primary key, name varchar(50));

insert into O_Roll_Call values(1,"ABC"),(2,"XYZ"),(3,"PQR");

insert into N_Roll_Call values(3,"PQR"),(4,"GGR"),(5,"GYG");

delimiter //

create procedure Merge()
     begin
     declare done INT DEFAULT FALSE;
     declare rno int;
     declare sname varchar(50);
     declare c1 cursor for select rollno,name from O_Roll_Call;
     declare continue handler for not found set done= TRUE;
     open c1;
     read_loop:loop
     fetch c1 into rno,sname;
     if done then
     leave read_loop;
     end if;
     if not exists(select 1 from N_Roll_Call where rollno=rno and name=sname) then

     insert into N_Roll_Call(rollno,name) values(rno,Sname);
     end if;
     end loop;
     close c1;
     end;
     //

delimiter ;

call Merge();

select * from O_Roll_Call;
select * from N_Roll_Call;
